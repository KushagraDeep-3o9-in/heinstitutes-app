<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { metaDescription }) %>
<body>
  <main class="container">
    <h1>Higher Education Institutes in India</h1>
    <p>Browse <%= states.reduce((s, x) => s + x.count, 0).toLocaleString() %> institutes across <%= states.length %> states and union territories, sourced from AISHE records.</p>
    <p><a href="/india-heinstitutes/programs">Browse institutes by programme/course &rarr;</a></p>
    <p><a href="/india-heinstitutes/disciplines">Browse institutes by discipline &rarr;</a></p>

    <%- include('partials/adslot') %>

    <ul class="state-grid">
      <% states.forEach(function(s) { %>
        <li>
          <a href="<%= buildStateUrl(s._id) %>"><%= s._id %></a>
          <span class="count"><%= s.count.toLocaleString() %> institutes</span>
        </li>
      <% }); %>
    </ul>
  </main>
</body>
</html>

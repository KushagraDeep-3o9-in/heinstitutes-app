<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { metaDescription }) %>
<body>
  <main class="container">
    <%- include('partials/breadcrumb', { items: [
      { name: 'Home', url: SITE_ORIGIN + '/india-heinstitutes' },
      { name: 'Browse by Programme', url: canonicalUrl }
    ] }) %>

    <h1>Browse Institutes by Programme</h1>
    <p><%= total.toLocaleString() %> programmes on file. Pick one to see every institute offering it, filterable by University, College, or Standalone Institution.</p>

    <%- include('partials/adslot', { slotId: '7777777777' }) %>

    <ul class="programme-list">
      <% programmes.forEach(function(p) { %>
        <li>
          <a href="/india-heinstitutes/programs/<%= p.programmeId %>"><%= p.programme %></a>
          <span class="meta"><%= p.level ? p.level + ' · ' : '' %><%= p.count.toLocaleString() %> institutes</span>
        </li>
      <% }); %>
    </ul>

    <% if (totalPages > 1) { %>
    <nav class="pagination" aria-label="pagination">
      <% if (page > 1) { %><a href="/india-heinstitutes/programs?page=<%= page - 1 %>">&laquo; Prev</a><% } %>
      <span>Page <%= page %> of <%= totalPages %></span>
      <% if (page < totalPages) { %><a href="/india-heinstitutes/programs?page=<%= page + 1 %>">Next &raquo;</a><% } %>
    </nav>
    <% } %>
  </main>
</body>
</html>
